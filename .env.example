# === База данных ===
# Пароль для PostgreSQL (обязательно)
POSTGRES_PASSWORD=change_me_to_random_string
POSTGRES_USER=funpay
POSTGRES_DB=funpay_bot

# === Шифрование ===
# Fernet ключ для шифрования секретов аккаунтов (пароли, токены, TOTP)
# Генерация: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# === JWT (админ-панель) ===
# Случайная строка для подписи JWT-токенов сессии
SECRET_KEY=

# Хеш пароля админа (bcrypt)
# Генерация: python -c "from passlib.hash import bcrypt; print(bcrypt.hash('ваш_пароль'))"
ADMIN_PASSWORD_HASH=

# Maximum scheduled Chromium refresh/revoke operations. Keep 1 on 2 GiB RAM.
BROWSER_CONCURRENCY_CAP=1

# === FunPay ===
# golden_key из cookies браузера (funpay.com → Application → Cookies → golden_key)
FUNPAY_SESSION_KEY=

# === Telegram (опционально) ===
TELEGRAM_BOT_TOKEN=
TELEGRAM_SELLER_CHAT_ID=

# === Microsoft Graph OAuth для Outlook/Hotmail (опционально) ===
MICROSOFT_GRAPH_CLIENT_ID=
MICROSOFT_GRAPH_CLIENT_SECRET=
MICROSOFT_GRAPH_REDIRECT_URI=

# === Домашний маршрут входа (опционально) ===
# HTTPS-адрес этой админки, из которого Windows скачивает установочный ZIP
# и куда отправляет одноразовый public-key enrollment.
HOME_RELAY_PUBLIC_BASE_URL=https://funpay-bot.duckdns.org
# Домен или IP сервера, к которому Windows подключает ограниченный SSH-туннель.
HOME_RELAY_PUBLIC_HOST=funpay-bot.duckdns.org
# Откройте этот TCP-порт на сервере/provider firewall только для SSH relay.
# Внутренний SOCKS-порт 1080 наружу не публикуется.
HOME_RELAY_SSH_PORT=2222
# Сервер проверяет маршрут раз в минуту. Если свежей успешной проверки нет,
# зависимые аккаунты автоматически исключаются из новых продаж.
PROXY_ROUTE_PROBE_INTERVAL_SECONDS=60
PROXY_ROUTE_MAX_AGE_SECONDS=180

# === DATABASE_URL вычисляется автоматически в docker-compose из POSTGRES_* ===
# При запуске БЕЗ docker укажите вручную:
# DATABASE_URL=postgresql+asyncpg://funpay:PASSWORD@localhost:5432/funpay_bot
